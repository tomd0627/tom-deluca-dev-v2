---
import Section from '../elements/Section.astro';
import SectionIntro from '../elements/SectionIntro.astro';
import SectionTitle from '../elements/SectionTitle.astro';
import ContactForm from '../elements/forms/ContactForm.astro';
import Icon from '../elements/Icon.astro';
---

<Section cssClass="section--contact" title="contact">
  <SectionIntro>
    <SectionTitle title="Let's work together" />
    <p class="animate-fade">
      I'm looking for a <strong>full-time front-end role</strong> and open to contract work. If something
      sounds like a fit, reach out.
    </p>
  </SectionIntro>
  <div class="contact-layout">
    <div class="contact-layout__form">
      <ContactForm />
    </div>
    <aside class="contact-layout__links animate-slide" aria-label="Contact links and resources">
      <div class="contact-links">
        <h3 class="contact-links__heading">Get in touch</h3>
        <ul class="contact-links__list">
          <li>
            <a
              id="contact-email"
              href="#"
              class="contact-links__item"
              aria-label="Email Tom DeLuca"
              data-v="dG9tZDA2MjdAZ21haWwuY29t"
            >
              <Icon name="envelope" />
              <span id="contact-email-text"></span>
            </a>
          </li>
          <li>
            <a
              id="contact-phone"
              href="#"
              class="contact-links__item"
              aria-label="Call Tom DeLuca"
              data-v="ODQ1LTk4Ny0yOTk4"
              data-t="MTg0NTk4NzI5OTg="
            >
              <Icon name="phone" />
              <span id="contact-phone-text"></span>
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/tomdeluca/"
              class="contact-links__item"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Tom DeLuca on LinkedIn (opens in new window)"
            >
              <Icon name="linkedin" />
              <span>LinkedIn</span>
            </a>
          </li>
        </ul>

        <h3 class="contact-links__heading">My Work</h3>
        <ul class="contact-links__list">
          <li>
            <a
              href="https://github.com/tomd0627"
              class="contact-links__item"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Tom DeLuca on GitHub (opens in new window)"
            >
              <Icon name="github" />
              <span>GitHub</span>
            </a>
          </li>
          <li>
            <a
              href="https://codepen.io/tomd0627"
              class="contact-links__item"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Tom DeLuca on CodePen (opens in new window)"
            >
              <Icon name="codepen" />
              <span>CodePen</span>
            </a>
          </li>
        </ul>

        <h3 class="contact-links__heading">Resumes</h3>
        <div class="contact-links__resumes">
          <a href="/files/Tom_DeLuca_Resume_Front_End.pdf" download class="button button--primary">
            <Icon name="file-lines" /> Front-End
          </a>
          <a
            href="/files/Tom_DeLuca_Resume_Office_Clerical.pdf"
            download
            class="button button--secondary"
          >
            <Icon name="file-lines" /> Office / Clerical
          </a>
        </div>
      </div>
    </aside>
  </div>
</Section>

<script>
  const emailEl = document.getElementById('contact-email') as HTMLAnchorElement | null;
  const phoneEl = document.getElementById('contact-phone') as HTMLAnchorElement | null;
  const emailText = document.getElementById('contact-email-text');
  const phoneText = document.getElementById('contact-phone-text');
  if (emailEl?.dataset.v && emailText) {
    const e = atob(emailEl.dataset.v);
    emailEl.href = 'mailto:' + e;
    emailText.textContent = e;
  }
  if (phoneEl?.dataset.v && phoneEl.dataset.t && phoneText) {
    const p = atob(phoneEl.dataset.v);
    const t = atob(phoneEl.dataset.t);
    phoneEl.href = 'tel:' + t;
    phoneText.textContent = p;
  }
</script>
