---
import Section from '../elements/Section.astro';
import SectionIntro from '../elements/SectionIntro.astro';
import SectionTitle from '../elements/SectionTitle.astro';
import ExperienceItem from '../elements/ExperienceItem.astro';
---

<Section cssClass="section--experience" title="experience">
  <SectionIntro>
    <SectionTitle title="My experience" />
    <p class="animate-fade">
      A decade of delivering for enterprise clients — from Fortune 500 brands to global financial
      institutions — with hands-on expertise across the full front-end stack.
    </p>
  </SectionIntro>
  <div class="experience-timeline">
    <ExperienceItem title="Senior Front-End Developer" company="Various Enterprise Clients">
      <ul class="experience-item__highlights">
        <li>
          Architected and maintained responsive web applications for Fortune 500 clients using
          React, Angular, and modern CSS frameworks
        </li>
        <li>
          Led component design and implementation via Storybook with consistent design systems;
          worked with GSAP, Tailwind CSS, and performance best practices
        </li>
        <li>
          Managed content and feature delivery in enterprise CMS platforms: Optimizely, Sitecore
          (SXA + Content Editor), Drupal, and WordPress
        </li>
        <li>
          Collaborated directly with designers, back-end teams, and stakeholders to deliver
          pixel-perfect, accessible implementations on time
        </li>
        <li>
          Worked across Angular, Vue.js, and Svelte on diverse client engagements; cross-browser
          compatibility and WCAG accessibility compliance throughout
        </li>
      </ul>
    </ExperienceItem>

    <ExperienceItem
      title="Office Administrator / Clerical Specialist"
      company="Various Organizations"
    >
      <ul class="experience-item__highlights">
        <li>
          Managed office operations, scheduling, and administrative systems; coordinated
          cross-departmental workflows improving efficiency by up to 30%
        </li>
        <li>
          Data entry, document management, and payroll processing with zero error rate; strong
          written and verbal communication with clients, vendors, and stakeholders
        </li>
        <li>Provides medical and legal transcription services with accuracy and confidentiality</li>
      </ul>
    </ExperienceItem>
  </div>
</Section>
