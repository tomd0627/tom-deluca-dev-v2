---
import Section from '../elements/Section.astro';
import SectionIntro from '../elements/SectionIntro.astro';
import SectionTitle from '../elements/SectionTitle.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import imgProjectRapid7 from '../../assets/images/projects/rapid7.png';
import imgProjectCiga from '../../assets/images/projects/ciga.png';
import imgProjectCencora from '../../assets/images/projects/cencora.png';
import imgProjectCorbion from '../../assets/images/projects/corbion.png';
import imgProjectRra from '../../assets/images/projects/rra.png';
import imgProjectAruba from '../../assets/images/projects/ob.png';
import imgProjectAb from '../../assets/images/projects/ab.png';
import imgProjectAsh from '../../assets/images/projects/ash.png';

interface BentoProject {
  name: string;
  challenge: string;
  tags: string[];
  image: ImageMetadata;
  alt: string;
  href: string;
  wide?: boolean;
  full?: boolean;
}

// TODO (Phase 4): Replace all href values with real client URLs
const projects: BentoProject[] = [
  {
    name: 'Rapid7',
    challenge:
      'Problem: stale content and accessibility gaps ahead of a platform migration. Solution: audited and fixed blockers, prepped codebase for migration.',
    tags: ['Optimizely', 'Performance', 'Responsive'],
    image: imgProjectRapid7,
    alt: 'Rapid7 website screenshot',
    href: 'https://www.rapid7.com/',
    wide: true,
  },
  {
    name: 'CIGA',
    challenge:
      "Problem: a legacy site couldn't support a new identity. Solution: rebuilt in Next.js + Tailwind, hitting strong Core Web Vitals with a clean, scalable structure.",
    tags: ['React', 'Next.js', 'Tailwind CSS'],
    image: imgProjectCiga,
    alt: 'California Insurance Guarantee Association website screenshot',
    href: 'https://www.ciga.org/',
  },
  {
    name: 'Cencora',
    challenge:
      'Problem: a full company rename needed a memorable launch experience. Solution: built a scroll-driven splash with GSAP, parallax layers, and SVG animations.',
    tags: ['GSAP', 'Sitecore', 'Animation'],
    image: imgProjectCencora,
    alt: 'Cencora website screenshot',
    href: 'https://www.cencora.com/',
  },
  {
    name: 'Russell Reynolds',
    challenge:
      'Problem: a site redesign needed a scalable, component-driven approach. Solution: built a Storybook component library and composed pages by stitching components together.',
    tags: ['Components', 'Storybook', 'Design Systems'],
    image: imgProjectRra,
    alt: 'Russell Reynolds Associates website screenshot',
    href: 'https://www.russellreynolds.com/',
    wide: true,
  },
  {
    name: 'Corbion',
    challenge:
      'Problem: critical issues surfaced in QA with the launch deadline imminent. Solution: audited, triaged, and resolved all blockers in time.',
    tags: ['Sitecore', 'QA'],
    image: imgProjectCorbion,
    alt: 'Corbion website screenshot',
    href: 'https://www.corbion.com/',
  },
  {
    name: 'Orco Bank',
    challenge:
      'Problem: fragmented design and poor performance on a legacy banking site. Solution: migrated to a modern Sitecore architecture with consistent design patterns throughout.',
    tags: ['Sitecore SXA', 'Migration'],
    image: imgProjectAruba,
    alt: 'Orco Bank website screenshot',
    href: 'https://www.orcobank.com/',
  },
  {
    name: 'AmerisourceBergen',
    challenge:
      'Problem: rebranding required unifying multiple business unit sites under one identity. Solution: built a scalable design system and component library across all units.',
    tags: ['Rebranding', 'Brand Systems', 'Components'],
    image: imgProjectAb,
    alt: 'AmerisourceBergen website screenshot',
    href: 'https://www.amerisourcebergen.com/',
  },
  {
    name: 'ASH',
    challenge:
      "Problem: rebuilding a medical society site required deep domain knowledge fast. Solution: partnered with the client's domain experts to ship an accessible, polished site on deadline.",
    tags: ['HTML', 'CSS', 'Launch'],
    image: imgProjectAsh,
    alt: 'American Society of Hematology website screenshot',
    href: 'https://www.hematology.org/',
    wide: true,
  },
];

// Compute placeholder grid-column spans so it always fills the remaining
// columns at each breakpoint — no orphans regardless of project count.
const totalSpansMd = projects.length; // all cells are span 1 at medium
const remainderMd = totalSpansMd % 2;
const placeholderSpanMd = remainderMd === 0 ? 2 : 1;

const totalSpansLg = projects.reduce((acc, p) => acc + (p.full ? 3 : p.wide ? 2 : 1), 0);
const remainderLg = totalSpansLg % 3;
const placeholderSpanLg = remainderLg === 0 ? 3 : 3 - remainderLg;
---

<Section cssClass="section--projects" title="projects">
  <SectionIntro>
    <SectionTitle title="Client projects" />
    <p class="animate-fade">Some of the sites I've helped build over the past several years.</p>
  </SectionIntro>
  <div class="project-bento">
    {
      projects.map((project) => (
        <a
          href={project.href}
          class={`project-bento__cell animate-slide${project.wide ? ' project-bento__cell--wide' : ''}${project.full ? ' project-bento__cell--full' : ''}`}
          aria-label={`View ${project.name} project (opens in new window)`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Image
            src={project.image}
            alt={project.alt}
            loading="lazy"
            class="project-bento__image"
            widths={[400, 700, 1000]}
            sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
          />
          <div class="project-bento__overlay" aria-hidden="true" />
          <div class="project-bento__content">
            <h3 class="project-bento__name">{project.name}</h3>
            <p class="project-bento__challenge">{project.challenge}</p>
            <div class="project-bento__tags">
              {project.tags.map((tag) => (
                <span class="project-bento__tag">{tag}</span>
              ))}
            </div>
          </div>
          <span class="project-bento__cta" aria-hidden="true">
            View project →
          </span>
        </a>
      ))
    }
    <div
      class="project-bento__placeholder animate-slide"
      aria-hidden="true"
      style={`--placeholder-col-md: span ${placeholderSpanMd}; --placeholder-col-lg: span ${placeholderSpanLg};`}
    >
      <span class="project-bento__placeholder-icon">+</span>
      <p class="project-bento__placeholder-label">More coming soon</p>
    </div>
  </div>
</Section>
