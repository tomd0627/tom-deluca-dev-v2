---
import SkillCard from '../elements/SkillCard.astro';
import Section from '../elements/Section.astro';
import SectionIntro from '../elements/SectionIntro.astro';
import SectionTitle from '../elements/SectionTitle.astro';
---

<Section cssClass="section--skills" title="skills">
  <SectionIntro>
    <SectionTitle title="My skills" />
    <p class="animate-fade">
      A comprehensive skill set that blends modern front-end development, enterprise platforms, and
      professional expertise to build reliable, maintainable experiences.
    </p>
  </SectionIntro>
  <div class="skill-card-list">
    <SkillCard name="Core Technologies" cssClass="core-skills" icon="code">
      <div class="skill-tags">
        <span class="skill-tag">HTML</span>
        <span class="skill-tag">CSS</span>
        <span class="skill-tag">JavaScript</span>
        <span class="skill-tag">TypeScript</span>
        <span class="skill-tag">React</span>
        <span class="skill-tag">Angular</span>
        <span class="skill-tag">Vue.js</span>
        <span class="skill-tag">Next.js</span>
        <span class="skill-tag">Svelte</span>
        <span class="skill-tag">Tailwind CSS</span>
        <span class="skill-tag">SASS/SCSS</span>
        <span class="skill-tag">GSAP</span>
        <span class="skill-tag">Storybook</span>
        <span class="skill-tag">Sitecore</span>
        <span class="skill-tag">Optimizely</span>
        <span class="skill-tag">WordPress</span>
        <span class="skill-tag">Drupal</span>
      </div>
    </SkillCard>

    <SkillCard name="Specialized Skills" cssClass="specialized-skills" icon="star">
      <ul>
        <li>Design translation & pixel-perfect implementation</li>
        <li>Responsive web design & cross-browser compatibility</li>
        <li>Web accessibility (WCAG 2.1 AA/AAA)</li>
        <li>Performance optimization & Core Web Vitals</li>
        <li>Email markup (MJML)</li>
        <li>Template engines: Handlebars.js, Mustache.js, Nunjucks</li>
        <li>AI tools: ChatGPT, Claude, Gemini, GitHub Copilot</li>
      </ul>
    </SkillCard>

    <SkillCard name="Professional Attributes" cssClass="professional-skills" icon="users">
      <ul>
        <li>Collaborative team player with cross-functional experience</li>
        <li>Clear communicator with design, back-end, and business teams</li>
        <li>Strong time management and deadline adherence</li>
        <li>Proactive problem-solver with solution-oriented mindset</li>
        <li>Adaptable and quick to learn new technologies</li>
        <li>Detail-oriented with high standards for code quality</li>
      </ul>
    </SkillCard>
  </div>
</Section>
