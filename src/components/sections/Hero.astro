---
import Section from '../elements/Section.astro';
import Icon from '../elements/Icon.astro';
---

<Section cssClass="section--hero" title="hero">
  <div class="hero">
    <p class="hero__eyebrow">Available for hire</p>
    <h1 class="hero__title">
      <span class="word">Senior</span>
      <span class="word">Front-End</span>
      <br />
      <span class="word">Developer</span>
    </h1>
    <p class="hero__subtitle">
      15+ years building production web experiences for Fortune 500 companies.
    </p>
    <ul class="hero__tech-stack" aria-label="Technology stack" role="list">
      <li>HTML</li>
      <li>CSS</li>
      <li>JavaScript</li>
      <li>React</li>
      <li>Angular</li>
      <li>Sitecore</li>
      <li>Optimizely</li>
      <li>Next.js</li>
    </ul>
    <div class="hero__ctas">
      <a href="#contact" class="button button--large button--primary">
        <Icon name="envelope" /> Let's work together
      </a>
      <a href="#projects" class="button button--large button--secondary">
        <Icon name="arrow-down" /> View my work
      </a>
    </div>
    <div class="hero__scroll-indicator" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </div>
</Section>
