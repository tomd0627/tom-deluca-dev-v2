---
import { Image } from 'astro:assets';
import imgHeadshot from '../../assets/images/headshot.png';
import Section from '../elements/Section.astro';
import SectionIntro from '../elements/SectionIntro.astro';
import SectionTitle from '../elements/SectionTitle.astro';
---

<Section cssClass="section--about" title="about">
  <SectionIntro>
    <SectionTitle title="About me" />
    <p class="animate-fade">
      Hi, I'm <span class="section__highlight">Tom DeLuca</span> — a senior front-end developer based
      in Warwick, New York with 10+ years building production web experiences.
    </p>
    <p class="animate-fade">
      I specialize in translating designs into <strong
        >pixel-perfect, accessible, high-performance interfaces</strong
      > — from enterprise CMS platforms to modern React/Next.js applications. My stack spans <span
        class="tech-tag">HTML</span
      >
      <span class="tech-tag">CSS</span>
      <span class="tech-tag">JavaScript</span>
      <span class="tech-tag">React</span>
      <span class="tech-tag">Angular</span>
      <span class="tech-tag">Sitecore</span>
      <span class="tech-tag">Optimizely</span> and beyond.
    </p>
    <p class="animate-fade">
      I thrive in cross-functional teams — working closely with designers, back-end engineers, and
      stakeholders to ship on time and at the quality bar enterprise clients demand.
    </p>
    <p class="animate-fade">
      Outside of code, I'm into anime, gaming, and spending time with family and friends.
    </p>
    <p class="animate-fade">
      <strong>Also available for:</strong> Transcription services and office operations consulting.
    </p>
  </SectionIntro>
  <div class="section__image animate-fade">
    <div class="section__image-inner">
      <Image src={imgHeadshot} alt="Tom DeLuca headshot" loading="eager" />
    </div>
  </div>
</Section>

<style>
  .tech-tag {
    background: rgba(94, 240, 200, 0.12);
    border: 1px solid rgba(94, 240, 200, 0.25);
    border-radius: 4px;
    color: var(--c-accent);
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    padding-block: 0.1rem;
    padding-inline: 0.5rem;
  }
</style>
