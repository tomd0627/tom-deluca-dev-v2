---
export interface Props {
  quote: string;
  name: string;
  title: string;
}

const { quote, name, title } = Astro.props;
---

<blockquote class="testimonial-card animate-slide">
  <span class="testimonial-card__mark" aria-hidden="true">&ldquo;</span>
  <p class="testimonial-card__quote">{quote}</p>
  <footer class="testimonial-card__footer">
    <cite>
      <span class="testimonial-card__name">{name}</span>
      <span class="testimonial-card__title">{title}</span>
    </cite>
  </footer>
</blockquote>
